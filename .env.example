# חובה — Neon PostgreSQL (Pooled connection)
# Pooled Neon URL — ללא channel_binding
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# אופציונלי מקומי — אם Windows מגדיר DATABASE_URL=localhost במערכת
# ARTIST_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# אופציונלי — Google Gemini (רק ל-fallback; פקודות בעברית מפורשות מקומית)
GEMINI_API_KEY=

# אופציונלי — דגם Gemini (ברירת מחדל: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# אופציונלי — הפעלת Gemini רק כשהמפרש המקומי נכשל (ברירת מחדל: כבוי)
AI_USE_GEMINI=false

# שער כניסה (JUSIC PLAY)
GATE_SECRET=JUSIC
GATE_ALLOW_SHORTCUT=true
GATE_ALLOW_BIOMETRIC=true
TRUST_PROXY=1
